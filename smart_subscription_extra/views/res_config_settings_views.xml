<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_smart_subscription" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.sb.subscription</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Smart Business" name="smart_subscription_extra"
                     data-string="Smart Business">

                    <block title="Suscripciones — Cargo por mora" name="smart_late_fee_block">
                        <setting string="Producto para cargo por mora"
                                 help="Producto de tipo Servicio que se usará en las facturas de mora generadas automáticamente.">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="smart_late_fee_product_id"
                                           widget="many2one"
                                           options="{'no_create': True}"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <block title="Integración Google Cloud Platform" name="smart_gcp_block">
                        <setting string="Service Account JSON (GCP)"
                                 help="Contenido del archivo JSON del Service Account de GCP. Requiere permiso compute.instances.stop.">
                            <div class="content-group">
                                <div class="mt8">
                                    <field name="smart_gcp_service_account_json"
                                           widget="text"
                                           placeholder='{"type": "service_account", ...}'/>
                                </div>
                            </div>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>
