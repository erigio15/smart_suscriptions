<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron: Apagado GCP por no pago (Req. 2) -->
        <record id="cron_gcp_shutdown_check" model="ir.cron">
            <field name="name">Smart: Apagado VM GCP por factura sin pago</field>
            <field name="model_id" ref="sale_subscription.model_sale_order"/>
            <field name="state">code</field>
            <field name="code">model._smart_cron_gcp_shutdown_check()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- Cron: Bloqueo de servidor (Req. 4) -->
        <record id="cron_gcp_block_check" model="ir.cron">
            <field name="name">Smart: Bloqueo de servidor VM GCP</field>
            <field name="model_id" ref="sale_subscription.model_sale_order"/>
            <field name="state">code</field>
            <field name="code">model._smart_cron_gcp_block_check()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>
